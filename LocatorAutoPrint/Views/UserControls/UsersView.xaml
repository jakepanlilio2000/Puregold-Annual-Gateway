<UserControl x:Class="LocatorAutoPrint.Views.UserControls.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
             Background="{StaticResource Brush.LightGray}">
    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL: FORM CARD -->
        <Border Grid.Row="0" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="User Management" Style="{StaticResource Text.Header}" FontSize="14" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="First Name" Style="{StaticResource Text.Body}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,0,8"/>

                        <TextBlock Text="Last Name" Style="{StaticResource Text.Body}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,0,8"/>

                        <TextBlock Text="Username" Style="{StaticResource Text.Body}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,0,8"/>

                        <TextBlock Text="Password" Style="{StaticResource Text.Body}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding RawPassword, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding AddUserCommand}" Style="{StaticResource PrimaryActionButton}" Height="30" Margin="0,0,4,6">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="UserPlus" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="Add User"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding EditUserCommand}" Style="{StaticResource SecondaryActionButton}" Height="30" Margin="4,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="UserPen" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="Update Selected"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding LogoutMobileAppCommand}" Style="{StaticResource WarningActionButton}" Height="30" Margin="0,0,4,6" ToolTip="Clears IP and active locator for selected user">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="MobileScreen" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="Logout Mobile"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding DeleteUserCommand}" Style="{StaticResource DestructiveActionButton}" Height="30" Margin="4,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="Trash" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="Delete Selected"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Button Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryActionButton}" Height="28" FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Eraser" FontSize="10" Margin="0,0,5,0"/>
                                <TextBlock Text="Clear Form"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- BOTTOM PANEL: DATAGRID CARD -->
        <Border Grid.Row="1" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,8">
                    <TextBlock Text="System Users" Style="{StaticResource Text.Header}" FontSize="14" VerticalAlignment="Center"/>
                    <Button Command="{Binding LoadUsersCommand}" Style="{StaticResource SecondaryActionButton}" Width="125" HorizontalAlignment="Right" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="ArrowsRotate" FontSize="10" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh List"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding UsersList}" SelectedItem="{Binding SelectedUser}" VerticalScrollBarVisibility="Hidden"
                          Style="{StaticResource ModernDataGrid}" ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Status" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding IpAddress}">
                                        <Ellipse Width="12" Height="12" StrokeThickness="1">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#BDC3C7"/>
                                                    <Setter Property="Stroke" Value="#7F8C8D"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                            <Setter Property="Fill" Value="#2ECC71"/>
                                                            <Setter Property="Stroke" Value="#27AE60"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding Fullname}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat={}{0:MM/dd/yy HH:mm}}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Active Loc" Binding="{Binding ActiveLocator}" Width="*" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="Session" Binding="{Binding IsLogin, Mode=OneWay}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>