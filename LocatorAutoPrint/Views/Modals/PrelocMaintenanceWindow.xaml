<Window x:Class="LocatorAutoPrint.Views.Modals.PrelocMaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="PRELOC Maintenance" Width="500" Height="400" 
        WindowStartupLocation="CenterOwner" 
        Background="{StaticResource Brush.LightGray}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ADD LOCATOR CARD -->
        <Border Grid.Row="0" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="SlotNo:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Body}"/>
                <TextBox Grid.Column="1" Text="{Binding NewSlotNo}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,12,0"/>

                <TextBlock Grid.Column="2" Text="Name:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Text.Body}"/>
                <TextBox Grid.Column="3" Text="{Binding NewLocatorName}" Style="{StaticResource ModernTextBox}" Height="28" Margin="0,0,12,0"/>

                <Button Grid.Column="4" Command="{Binding AddPrelocCommand}" Style="{StaticResource PrimaryActionButton}" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Plus" FontSize="10" Margin="0,0,6,0"/>
                        <TextBlock Text="Add"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- DATAGRID CARD -->
        <Border Grid.Row="1" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12">
            <DataGrid ItemsSource="{Binding PrelocList}" SelectedItem="{Binding SelectedPreloc}" 
                      Style="{StaticResource ModernDataGrid}" ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SlotNo" Binding="{Binding SlotNo}" IsReadOnly="True" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTemplateColumn Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Command="{Binding DataContext.EditPrelocCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource SecondaryActionButton}" Padding="8,4" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconBlock Icon="FloppyDisk" FontSize="9" Margin="0,0,4,0"/>
                                            <TextBlock Text="Save" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeletePrelocCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource DestructiveActionButton}" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconBlock Icon="Trash" FontSize="9" Margin="0,0,4,0"/>
                                            <TextBlock Text="Del" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>