<Window x:Class="LocatorAutoPrint.Views.Modals.CountsheetDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Locator Records Details" Width="900" Height="500" 
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.LightGray}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER CARD -->
        <Border Grid.Row="0" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" 
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <fa:IconBlock Icon="FileLines" Foreground="{StaticResource Brush.PrimaryBlue}" 
                              FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Locator Records Details" Style="{StaticResource Text.Header}" 
                           FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DATAGRID CARD -->
        <Border Grid.Row="1" Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" 
                BorderThickness="1" CornerRadius="6" Padding="12">
            <DataGrid ItemsSource="{Binding SelectedLocatorDetails}" 
                      Style="{StaticResource ModernDataGrid}" ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Locator" Binding="{Binding SlotNo}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Rec No." Binding="{Binding RecNo}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding CountDate}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="UPC" Binding="{Binding UPC}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Descr}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Qty}" Width="70" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Added" Binding="{Binding Added}" Width="55" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Edited" Binding="{Binding Edited}" Width="55" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>