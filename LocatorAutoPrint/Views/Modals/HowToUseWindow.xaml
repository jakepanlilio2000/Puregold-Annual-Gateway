<Window x:Class="LocatorAutoPrint.Views.Modals.HowToUseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="How to Use" Width="550" Height="480" 
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow" 
        Background="{StaticResource Brush.LightGray}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER CARD -->
        <Border Grid.Row="0" Background="{StaticResource Brush.DarkBlue}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <fa:IconBlock Icon="BookOpen" Foreground="{StaticResource Brush.PrimaryYellow}" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Comprehensive User Guide (v3.0)" Foreground="{StaticResource Brush.White}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Section 1 -->
                <Border Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Print" Foreground="{StaticResource Brush.PrimaryBlue}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="1. Printing Locators" Style="{StaticResource Text.Header}" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Text="• Enter locator numbers separated by periods (e.g., 1.2.3) or ranges (e.g., 5-10).&#x0a;• Click 'OK' to start printing. The system automatically verifies if the locator is closed and backs up the countsheet to a text file before sending it to the default printer." TextWrapping="Wrap" Style="{StaticResource Text.Body}" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <!-- Section 2 -->
                <Border Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="FilePen" Foreground="{StaticResource Brush.PrimaryBlue}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="2. Editing Count Sheets" Style="{StaticResource Text.Header}" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Text="• Navigate to the 'Edit Count Sheet' tab.&#x0a;• Enter the Locator and Record No. to load the item.&#x0a;• You can search Masterfile items by UPC or SKU.&#x0a;• Only 'Edited Qty', 'UPC', 'SKU', and 'Description' can be modified. Original Qty remains intact." TextWrapping="Wrap" Style="{StaticResource Text.Body}" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <!-- Section 3 -->
                <Border Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="ChartColumn" Foreground="{StaticResource Brush.PrimaryBlue}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="3. Reports &amp; Monitoring" Style="{StaticResource Text.Header}" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Text="• INF Report: View and export 'Item Not Found' entries to PDF.&#x0a;• SKU Inquiry: Search items directly from the Masterfile.&#x0a;• Summary: View aggregated counts, quantities, and SKUs per locator.&#x0a;• Stock Value: Check current stock amounts and unit costs." TextWrapping="Wrap" Style="{StaticResource Text.Body}" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <!-- Section 4 -->
                <Border Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Users" Foreground="{StaticResource Brush.PrimaryBlue}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="4. User Management" Style="{StaticResource Text.Header}" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Text="• Manage user access, monitor active locators, and view login statuses.&#x0a;• Use 'Logout to Mobile App' to clear stuck mobile sessions." TextWrapping="Wrap" Style="{StaticResource Text.Body}" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <!-- Section 5 -->
                <Border Background="{StaticResource Brush.White}" BorderBrush="{StaticResource Brush.NeutralGray}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Gears" Foreground="{StaticResource Brush.PrimaryBlue}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="5. Locator Maintenance &amp; Restore" Style="{StaticResource Text.Header}" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Text="• Manage active/closed statuses globally from the Print Locator tab.&#x0a;• Restore locators safely from auto-generated text backups if database records are compromised." TextWrapping="Wrap" Style="{StaticResource Text.Body}" Foreground="#555"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>